MainTab:AddSection("Toggle")
MainTab:AddToggle({
    Name = "Auto Wall Hop",
    Default = false,
    Flag = "auto_farm",
    Callback = function(v)
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- Settings
local WALL_HOP_FORCE = 45
local PUSH_BACK_FORCE = 18
local MAX_DETECTION_DIST = 3

local isWallHopping = false

-- Global attribute that the UI can toggle
player:SetAttribute("WallHopEnabled", v)

local function checkWall()
	if not rootPart then return nil, nil end
	
	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = {character}
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	
	local lookDirection = rootPart.CFrame.LookVector
	local raycastResult = workspace:Raycast(rootPart.Position, lookDirection * MAX_DETECTION_DIST, raycastParams)
	
	if raycastResult then
		return raycastResult.Instance, raycastResult.Normal
	end
	return nil, nil
end

UserInputService.JumpRequest:Connect(function()
	-- Check if the feature is enabled via our in-game UI setting
	if not player:GetAttribute("WallHopEnabled") then return end

	if humanoid:GetState() == Enum.HumanoidStateType.Freefall and not isWallHopping then
		local wall, wallNormal = checkWall()
		
		if wall then
			isWallHopping = true
			humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
			
			local jumpVelocity = Vector3.new(0, WALL_HOP_FORCE, 0) + (wallNormal * PUSH_BACK_FORCE)
			rootPart.AssemblyLinearVelocity = jumpVelocity
			
			task.wait(0.25) 
			isWallHopping = false
		end
	end
end)

player.CharacterAdded:Connect(function(newCharacter)
	character = newCharacter
	humanoid = character:WaitForChild("Humanoid")
	rootPart = character:WaitForChild("HumanoidRootPart")
end)
    Window:Notify({
      Title = "Toggle",
      Content = tostring(v) ,
      Duration = 3
    })
  end
})

MainTab:AddToggle({
  Name = "Esp Player",
  Default = false,
  Flag = "auto_farm",
  Callback = function(createESP)
   local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Configuration
local ESP_COLOR = Color3.fromRGB(0, 255, 128) -- Bright neon green
local TEXT_SIZE = 14

-- Function to create 2D screen elements for a player
local function createESP(player)
	if player == LocalPlayer then return end

	-- Create a ScreenGui inside the PlayerGui so it draws on the screen
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name = player.Name .. "_ESP"
	screenGui.ResetOnSpawn = false
	screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

	-- Create the Box Outline
	local box = Instance.new("Frame")
	box.BackgroundTransparency = 1
	box.BorderColor3 = ESP_COLOR
	box.BorderSizePixel = 2
	box.Visible = false
	box.Parent = screenGui

	-- Create the Name Tag
	local nameTag = Instance.new("TextLabel")
	nameTag.BackgroundTransparency = 1
	nameTag.TextColor3 = ESP_COLOR
	nameTag.TextSize = TEXT_SIZE
	nameTag.Font = Enum.Font.SourceSansBold
	nameTag.TextStrokeTransparency = 0 -- Gives it a black outline so it's readable
	nameTag.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
	nameTag.Visible = false
	nameTag.Parent = screenGui

	-- Update loop using RenderStepped (runs every frame before rendering)
	local connection
	connection = RunService.RenderStepped:Connect(function()
		-- Check if the target player and their character still exist
		if not player or not player.Parent or not player.Character or not player.Character:FindFirstChild("HumanoidRootPart") then
			if not player or not player.Parent then
				-- If the player left the game, clean up the GUI and stop the loop
				screenGui:Destroy()
				connection:Disconnect()
			else
				-- If they are just dead/respawning, hide the UI temporarily
				box.Visible = false
				nameTag.Visible = false
			end
			return
		end

		local character = player.Character
		local hrp = character.HumanoidRootPart
		local humanoid = character:FindFirstChildOfClass("Humanoid")

		-- Don't show ESP if the player is dead
		if humanoid and humanoid.Health <= 0 then
			box.Visible = false
			nameTag.Visible = false
			return
		end

		-- Convert 3D World Position to 2D Screen Position
		local hrpPosition = hrp.Position
		local screenPos, onScreen = Camera:WorldToViewportPoint(hrpPosition)

		if onScreen then
			-- Calculate dynamic box scale based on distance from the camera
			local distance = (Camera.CFrame.Position - hrpPosition).Magnitude
			local scaleFactor = 1 / (distance * math.tan(math.rad(Camera.FieldOfView / 2))) * 1000
			
			local boxWidth = math.clamp(scaleFactor * 1.5, 20, 150)
			local boxHeight = math.clamp(scaleFactor * 2.5, 30, 250)

			-- Position and size the 2D Box
			box.Size = UDim2.new(0, boxWidth, 0, boxHeight)
			box.Position = UDim2.new(0, screenPos.X - (boxWidth / 2), 0, screenPos.Y - (boxHeight / 2))
			box.Visible = true

			-- Position and update the Text Label
			nameTag.Text = string.format("%s [%d Studs]", player.Name, math.floor(distance))
			nameTag.Size = UDim2.new(0, 200, 0, 20)
			nameTag.Position = UDim2.new(0, screenPos.X - 100, 0, screenPos.Y - (boxHeight / 2) - 25)
			nameTag.Visible = true
		else
			-- Hide elements if the player is behind the camera/walls orientation
			box.Visible = false
			nameTag.Visible = false
		end
	end)
end

-- Initialize for existing players
for _, player in ipairs(Players:GetPlayers()) do
	createESP(player)
end

-- Listen for new players joining
Players.PlayerAdded:Connect(createESP)
  end
})
        

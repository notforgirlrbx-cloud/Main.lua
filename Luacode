  end
})

MainTab:AddToggle({
    Name = "Infinite Jump",
    Default = false,
    Flag = "infinite_jump",
    Callback = function(state)
        _G.InfiniteJump = state -- Stores the toggle state in a global variable
    end
})

-- The background script that handles the actual jumping physics
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Connect to the JumpRequest event (fires whenever the player presses the jump key/button)
UserInputService.JumpRequest:Connect(function()
    if _G.InfiniteJump then
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                -- ChangeState forces the character to jump even if they are in mid-air
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end
end)

MainTab:AddToggle({
    Name = "Esp Player",
    Default = false,
    Flag = "player_esp", -- Changed flag to match ESP
    Callback = function(v)
        _G.EspEnabled = v
        
        local Players = game:GetService("Players")
        local LocalPlayer = Players.LocalPlayer

        -- Function to create ESP Highlight on a character
        local function createESP(player)
            if player == LocalPlayer then return end
            
            local function applyHighlight(character)
                -- Wait for root part to ensure character is fully loaded
                character:WaitForChild("HumanoidRootPart", 5)
                
                -- Check if highlight already exists
                if character:FindFirstChild("ESPHighlight") then return end
                
                local highlight = Instance.new("Highlight")
                highlight.Name = "ESPHighlight"
                highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Red fill
                highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- White border
                highlight.FillTransparency = 0.5
                highlight.OutlineTransparency = 0
                highlight.Adornee = character
                highlight.Parent = character
            end

            if player.Character then
                applyHighlight(player.Character)
            end
            
            player.CharacterAdded:Connect(applyHighlight)
        end

        -- Clean up highlights when turned off
        local function removeESP()
            for _, player in pairs(Players:GetPlayers()) do
                if player.Character and player.Character:FindFirstChild("ESPHighlight") then
                    player.Character.ESPHighlight:Destroy()
                end
            end
        end

        -- Main loop / toggle handling
        if _G.EspEnabled then
            -- Apply to current players
            for _, player in pairs(Players:GetPlayers()) do
                createESP(player)
            end
            
            -- Listen for new players joining
            _G.PlayerAddedConnection = Players.PlayerAdded:Connect(createESP)
        else
            -- Clean up everything when toggled off
            if _G.PlayerAddedConnection then
                _G.PlayerAddedConnection:Disconnect()
            end
            removeESP()
        end
    end
})

MainTab:AddToggle({
    Name = "Admin Fly",
    Default = false,
    Flag = "admin_fly",
    Callback = function(v)
        -- Services and Player Variables Setup
        local RunService = game:GetService("RunService")
        local UserInputService = game:GetService("UserInputService")
        local Players = game:GetService("Players")

        local player = Players.LocalPlayer
        local camera = workspace.CurrentCamera
        local character = player.Character or player.CharacterAdded:Wait()
        local rootPart = character:WaitForChild("HumanoidRootPart", 5)
        local humanoid = character:WaitForChild("Humanoid", 5)
        
        -- Global speed configuration
        getgenv().MobileFlySpeed = 45 -- Slightly lowered for easier mobile steering

        if v then
            -- === TURN FLY ON ===
            if rootPart:FindFirstChild("FlyAttachment") then rootPart.FlyAttachment:Destroy() end
            if getgenv().MobileFlyConnection then getgenv().MobileFlyConnection:Disconnect() end

            -- Prevent character from falling over
            humanoid.PlatformStand = true

            local attachment = Instance.new("Attachment")
            attachment.Name = "FlyAttachment"
            attachment.Parent = rootPart

            local linearVelocity = Instance.new("LinearVelocity")
            linearVelocity.Name = "FlyVelocity"
            linearVelocity.Attachment0 = attachment
            linearVelocity.MaxForce = math.huge
            linearVelocity.Velocity = Vector3.new(0, 0, 0)
            linearVelocity.RelativeTo = Enum.ActuatorRelativeTo.World
            linearVelocity.Parent = rootPart

            local alignOrientation = Instance.new("AlignOrientation")
            alignOrientation.Name = "FlyOrientation"
            alignOrientation.Attachment0 = attachment
            alignOrientation.MaxTorque = math.huge
            alignOrientation.Responsiveness = 200
            alignOrientation.Mode = Enum.OrientationMode.OneAttachment
            alignOrientation.CFrame = rootPart.CFrame
            alignOrientation.Parent = rootPart

            -- Mobile-Optimized Flight Loop
            getgenv().MobileFlyConnection = RunService.RenderStepped:Connect(function()
                if not character.Parent or not rootPart.Parent or not linearVelocity.Parent then
                    if getgenv().MobileFlyConnection then getgenv().MobileFlyConnection:Disconnect() end
                    return
                end

                -- 1. Get horizontal movement direction directly from the mobile thumbstick
                local moveDirection = humanoid.MoveDirection

                -- 2. Modify direction based on vertical camera angle (tilt phone up/down to change altitude)
                if moveDirection.Magnitude > 0 then
                    -- This links the thumbstick vector to your mobile camera's pitch angle
                    moveDirection = camera.CFrame:VectorToWorldSpace(camera.CFrame:VectorToObjectSpace(moveDirection))
                end

                -- 3. Mobile Jump Button Check (Fly Upwards)
                -- Checking if the jump state is active handles pressing the on-screen jump button
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) or humanoid.Jump then
                    moveDirection = moveDirection + Vector3.new(0, 1, 0)
                end

                -- Apply calculated mobile vector forces
                if moveDirection.Magnitude > 0 then
                    linearVelocity.Velocity = moveDirection.Unit * getgenv().MobileFlySpeed
                else
                    linearVelocity.Velocity = Vector3.new(0, 0, 0)
                end

                -- Keep character rotated toward where the camera faces
                local camLook = camera.CFrame.LookVector
                alignOrientation.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + Vector3.new(camLook.X, 0, camLook.Z))
            end)
            
        else
            -- === TURN FLY OFF ===
            if getgenv().MobileFlyConnection then
                getgenv().MobileFlyConnection:Disconnect()
                getgenv().MobileFlyConnection = nil
            end

            if humanoid then
                humanoid.PlatformStand = false
            end

            if rootPart then
                local attachment = rootPart:FindFirstChild("FlyAttachment")
                local velocity = rootPart:FindFirstChild("FlyVelocity")
                local orientation = rootPart:FindFirstChild("FlyOrientation")

                if attachment then attachment:Destroy() end
                if velocity then velocity:Destroy() end
                if orientation then orientation:Destroy() end
            end
        end
    end
})


MainTab:AddSection("Toggle")
MainTab:AddToggle({
    Name = "Auto Wall Hop",
    Default = false,
    Flag = "auto_farm",
    Callback = function(v)
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoid = character:WaitForChild("Humanoid")
local rootPart = character:WaitForChild("HumanoidRootPart")

-- Settings
local WALL_HOP_FORCE = 45
local PUSH_BACK_FORCE = 18
local MAX_DETECTION_DIST = 3

local isWallHopping = false

-- Global attribute that the UI can toggle
player:SetAttribute("WallHopEnabled", v)

local function checkWall()
	if not rootPart then return nil, nil end
	
	local raycastParams = RaycastParams.new()
	raycastParams.FilterDescendantsInstances = {character}
	raycastParams.FilterType = Enum.RaycastFilterType.Exclude
	
	local lookDirection = rootPart.CFrame.LookVector
	local raycastResult = workspace:Raycast(rootPart.Position, lookDirection * MAX_DETECTION_DIST, raycastParams)
	
	if raycastResult then
		return raycastResult.Instance, raycastResult.Normal
	end
	return nil, nil
end

UserInputService.JumpRequest:Connect(function()
	-- Check if the feature is enabled via our in-game UI setting
	if not player:GetAttribute("WallHopEnabled") then return end

	if humanoid:GetState() == Enum.HumanoidStateType.Freefall and not isWallHopping then
		local wall, wallNormal = checkWall()
		
		if wall then
			isWallHopping = true
			humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
			
			local jumpVelocity = Vector3.new(0, WALL_HOP_FORCE, 0) + (wallNormal * PUSH_BACK_FORCE)
			rootPart.AssemblyLinearVelocity = jumpVelocity
			
			task.wait(0.25) 
			isWallHopping = false
		end
	end
end)

player.CharacterAdded:Connect(function(newCharacter)
	character = newCharacter
	humanoid = character:WaitForChild("Humanoid")
	rootPart = character:WaitForChild("HumanoidRootPart")
end)
    Window:Notify({
      Title = "Toggle",
      Content = tostring(v) ,
      Duration = 3
    })
  end
})

MainTab:AddToggle({
    Name = "Infinite Jump",
    Default = false,
    Flag = "infinite_jump",
    Callback = function(state)
        _G.InfiniteJump = state -- Stores the toggle state in a global variable
    end
})

-- The background script that handles the actual jumping physics
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Connect to the JumpRequest event (fires whenever the player presses the jump key/button)
UserInputService.JumpRequest:Connect(function()
    if _G.InfiniteJump then
        local character = LocalPlayer.Character
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                -- ChangeState forces the character to jump even if they are in mid-air
                humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
            end
        end
    end
end)

MainTab:AddToggle({
    Name = "Esp Player",
    Default = false,
    Flag = "player_esp", -- Changed flag to match ESP
    Callback = function(v)
        _G.EspEnabled = v
        
        local Players = game:GetService("Players")
        local LocalPlayer = Players.LocalPlayer

        -- Function to create ESP Highlight on a character
        local function createESP(player)
            if player == LocalPlayer then return end
            
            local function applyHighlight(character)
                -- Wait for root part to ensure character is fully loaded
                character:WaitForChild("HumanoidRootPart", 5)
                
                -- Check if highlight already exists
                if character:FindFirstChild("ESPHighlight") then return end
                
                local highlight = Instance.new("Highlight")
                highlight.Name = "ESPHighlight"
                highlight.FillColor = Color3.fromRGB(255, 0, 0) -- Red fill
                highlight.OutlineColor = Color3.fromRGB(255, 255, 255) -- White border
                highlight.FillTransparency = 0.5
                highlight.OutlineTransparency = 0
                highlight.Adornee = character
                highlight.Parent = character
            end

            if player.Character then
                applyHighlight(player.Character)
            end
            
            player.CharacterAdded:Connect(applyHighlight)
        end

        -- Clean up highlights when turned off
        local function removeESP()
            for _, player in pairs(Players:GetPlayers()) do
                if player.Character and player.Character:FindFirstChild("ESPHighlight") then
                    player.Character.ESPHighlight:Destroy()
                end
            end
        end

        -- Main loop / toggle handling
        if _G.EspEnabled then
            -- Apply to current players
            for _, player in pairs(Players:GetPlayers()) do
                createESP(player)
            end
            
            -- Listen for new players joining
            _G.PlayerAddedConnection = Players.PlayerAdded:Connect(createESP)
        else
            -- Clean up everything when toggled off
            if _G.PlayerAddedConnection then
                _G.PlayerAddedConnection:Disconnect()
            end
            removeESP()
        end
    end
})

MainTab:AddToggle({
    Name = "Fly",
    Default = false,
    Flag = "fly_toggle",
    Callback = function(state)
        local Players = game:Service("Players")
        local LocalPlayer = Players.LocalPlayer
        local RunService = game:GetService("RunService")
        
        -- Fly settings
        _G.FlySpeed = 50 -- Adjust this value to change fly speed
        
        if state then
            _G.Flying = true
            
            task.spawn(function()
                local Character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
                local Humanoid = Character:WaitForChild("Humanoid")
                local RootPart = Character:WaitForChild("HumanoidRootPart")
                local Camera = workspace.CurrentCamera
                
                -- Create a BodyVelocity to keep the player hovering/moving
                local bv = Instance.new("BodyVelocity")
                bv.Name = "FlyVelocity"
                bv.MaxForce = Vector3.new(0, 0, 0) -- Initially 0, handled in the loop
                bv.Velocity = Vector3.new(0, 0, 0)
                bv.Parent = RootPart
                
                -- Create a BodyGyro to keep the player upright and facing forward
                local bg = Instance.new("BodyGyro")
                bg.Name = "FlyGyro"
                bg.MaxForce = Vector3.new(0, 0, 0)
                bg.C99999 = bg.C99999 -- dummy, ignore
                bg.CFrame = RootPart.CFrame
                bg.Parent = RootPart
                
                -- Change humanoid state to prevent falling animations
                Humanoid.PlatformStand = true
                
                -- Movement loop
                while _G.Flying and Character and RootPart and Humanoid and Humanoid.Parent do
                    RunService.RenderStepped:Wait()
                    
                    bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                    bg.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                    bg.CFrame = Camera.CFrame
                    
                    local moveDirection = Vector3.new(0, 0, 0)
                    
                    -- Read core movement input from the player's Humanoid
                    -- This ensures support for both Keyboard (WASD) and Mobile Joysticks!
                    if Humanoid.MoveDirection.Magnitude > 0 then
                        moveDirection = Humanoid.MoveDirection
                    end
                    
                    -- Check for Up/Down movement (Spacebar / Mobile Jump button)
                    if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.Space) then
                        moveDirection = moveDirection + Vector3.new(0, 1, 0)
                    elseif game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.LeftControl) then
                        moveDirection = moveDirection + Vector3.new(0, -1, 0)
                    end
                    
                    -- Set the final velocity
                    bv.Velocity = moveDirection * _G.FlySpeed
                end
                
                -- Cleanup when toggle is turned off
                if bv then bv:Destroy() end
                if bg then bg:Destroy() end
                if Humanoid then Humanoid.PlatformStand = false end
            end)
        else
            -- Turn off flying flag to break the loop
            _G.Flying = false
            
            -- Manual cleanup fallback in case the loop didn't finish cleanly
            local Character = LocalPlayer.Character
            if Character then
                local RootPart = Character:FindFirstChild("HumanoidRootPart")
                local Humanoid = Character:FindFirstChild("Humanoid")
                if RootPart then
                    if RootPart:FindFirstChild("FlyVelocity") then RootPart.FlyVelocity:Destroy() end
                    if RootPart:FindFirstChild("FlyGyro") then RootPart.FlyGyro:Destroy() end
                end
                if Humanoid then
                    Humanoid.PlatformStand = false
                end
            end
        end
    end
})

